<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="24dp">

    <TextView android:id="@+id/titleText" android:text="Device Relay" android:textSize="24sp" android:textStyle="bold" android:layout_marginTop="32dp" android:layout_marginBottom="8dp"/>
    <TextView android:id="@+id/statusText" android:text="Service: Stopped 🔴" android:textSize="18sp" android:layout_marginTop="16dp" android:layout_marginBottom="24dp"/>
    <TextView android:id="@+id/tokenText" android:text="Bot Token: ...last6" android:textSize="14sp" android:textColor="#666" android:layout_marginBottom="8dp"/>
    <TextView android:id="@+id/chatIdText" android:text="Chat ID: " android:textSize="14sp" android:textColor="#666" android:layout_marginBottom="24dp"/>
    <TextView android:id="@+id/permissionWarningText" android:text="" android:textSize="14sp" android:textColor="#F00" android:layout_marginBottom="16dp"/>
    <Button android:id="@+id/toggleButton" android:text="Start Service" android:textAllCaps="false" android:paddingHorizontal="32dp" android:layout_marginBottom="16dp"/>
    <Button android:id="@+id/grantPermissionsButton" android:text="Grant Permissions" android:textAllCaps="false" android:paddingHorizontal="32dp"/>

</LinearLayout>